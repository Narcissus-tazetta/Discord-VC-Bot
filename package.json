{
    "name": "vc-bot",
    "version": "1.0.0",
    "description": "Temporary private voice channel Discord bot",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "bun run src/index.ts",
        "typecheck": "bunx tsc --noEmit",
        "build": "bun build src/index.ts --target bun --outdir dist"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "discord.js": "^14.25.1",
        "dotenv": "^17.3.1"
    }
}
